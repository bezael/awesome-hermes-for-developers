# Copy to .env (or your secrets manager equivalent) and fill in real values
# out of band. Never commit a filled-in copy of this file.
#
# The DSN below must point at the hermes_readonly role created by
# templates/readonly-role.sql — not at the application's owner/migration
# credentials.

# Full connection URI. Prefer verify-full over require when you have a CA
# you trust to pin against.
POSTGRES_READONLY_URL=postgresql://hermes_readonly:CHANGE_ME@db.internal:5432/app_production?sslmode=verify-full

# Defense-in-depth ceilings the application layer enforces in addition to
# the role-level settings already applied by readonly-role.sql. Keep these
# equal to or stricter than the role-level values — never looser.
PG_STATEMENT_TIMEOUT_MS=5000
PG_DEFAULT_ROW_LIMIT=200
PG_MAX_ROW_LIMIT=5000

# Optional: path to a CA bundle for sslmode=verify-full.
PGSSLROOTCERT=/etc/ssl/certs/production-ca.pem
